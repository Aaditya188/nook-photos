# Copy to indexer.env and edit. The Node server must be started with the SAME
# NOOK_INDEXER_SECRET so it can talk to the indexer.
NOOK_DATA_DIR=/home/raspberrypi/nook-photos/server/data
NOOK_INDEXER_PORT=8091
NOOK_INDEXER_SECRET=change-me-to-a-long-random-string
NOOK_ENABLE_FACES=1
NOOK_INDEX_POLL_SEC=20
